# ─── Server ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/bangui-est-doux
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/bangui-est-doux

# ─── JWT ─────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_!@#$%
JWT_EXPIRE=30d

# ─── Frontend URL ─────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Firebase Storage ─────────────────────────────
FIREBASE_PROJECT_ID=bangui-est-doux
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@bangui-est-doux.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=bangui-est-doux.appspot.com

# ─── Email (Nodemailer) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=banguiestdouxx@gmail.com
SMTP_PASS=your_app_password

# ─── Stripe Payments ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Google Maps ─────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ─── Admin defaults ───────────────────────────────
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@banguiestdoux.com
ADMIN_PASSWORD=Admin@2025!
