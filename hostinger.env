# =============================================================================
# BANGUI EST DOUX — Hostinger Environment Variables
# Copy every line below into hPanel → Node.js → Environment Variables
# Lines marked  ⚠️ FILL IN  require your own value before saving
# =============================================================================


# ── NODE ──────────────────────────────────────────────────────────────────────
NODE_ENV=production


# ── SUPABASE (public — safe to commit) ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://mhuryekpudxqyhuwnffu.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_IjkZzNCW_HChYZflbSzqxA_0qw05n0q
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_IjkZzNCW_HChYZflbSzqxA_0qw05n0q

# Backend uses the non-prefixed URL + the SECRET service-role key
SUPABASE_URL=https://mhuryekpudxqyhuwnffu.supabase.co
SUPABASE_ANON_KEY=sb_publishable_IjkZzNCW_HChYZflbSzqxA_0qw05n0q

# ⚠️ FILL IN — Supabase Dashboard → your project → Settings → API → service_role (eyJ…)
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY_HERE


# ── APP URLS ─────────────────────────────────────────────────────────────────
# ⚠️ FILL IN — replace with your actual Hostinger domain
NEXT_PUBLIC_APP_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com


# ── JWT (backend auth tokens) ─────────────────────────────────────────────────
# ⚠️ FILL IN — use any long random string (min 32 chars), keep it secret
JWT_SECRET=PASTE_A_LONG_RANDOM_SECRET_HERE
JWT_EXPIRE=30d


# ── SMTP — Gmail (for contact form & order emails) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=banguiestdouxx@gmail.com
# ⚠️ FILL IN — Gmail App Password (not your normal password)
# Create one at: myaccount.google.com → Security → App Passwords
SMTP_PASS=PASTE_GMAIL_APP_PASSWORD_HERE


# ── INITIAL ADMIN ACCOUNT (used by seed script on first run) ─────────────────
ADMIN_NAME=Admin BED
ADMIN_EMAIL=banguiestdouxx@gmail.com
# ⚠️ FILL IN — password you want for the admin account
ADMIN_PASSWORD=PASTE_ADMIN_PASSWORD_HERE
